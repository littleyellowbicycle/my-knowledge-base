# ===== 国产大模型 API Key (按需填写，留空则使用默认兜底) =====
# DeepSeek (问答流 C1 推荐)
DEEPSEEK_API_KEY=

# 智谱 GLM (加工层 B2 推荐)
ZHIPUAI_API_KEY=

# 月之暗面 Kimi (编译层 B4 推荐)
MOONSHOT_API_KEY=

# ===== LiteLLM 全局开关 =====
# 启用详细日志 (true/false)
LITELLM_LOG=INFO

# ===== 默认模型路由 (按层指定) =====
# 取值参考: deepseek/deepseek-chat | zhipu/glm-4-flash | moonshot/moonshot-v1-128k | ollama/qwen2.5:7b
MODEL_PROCESS=zhipu/glm-4-flash
MODEL_WIKI=moonshot/moonshot-v1-128k
MODEL_QA=deepseek/deepseek-chat
MODEL_FALLBACK=ollama/qwen2.5:7b

# ===== Jina Reader API (微信抓取) =====
# 可选，留空则走匿名调用 (有速率限制)
JINA_API_KEY=

# ===== 路径配置 (一般无需修改) =====
KB_ROOT=my_kb
